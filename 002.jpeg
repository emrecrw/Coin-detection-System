from pathlib import Path
import yaml

# Chemins
PROJECT_ROOT = Path(__file__).resolve().parent.parent
DATA_DIR = PROJECT_ROOT / "data"
RAW_DATA_DIR = DATA_DIR / "raw"
PROCESSED_DATA_DIR = DATA_DIR / "processed"
ANNOTATIONS_DIR = DATA_DIR / "annotations"
MODELS_DIR = PROJECT_ROOT / "models"
EXAMPLES_DIR = PROJECT_ROOT / "examples"

DATA_YAML = DATA_DIR / "data.yaml"
DEFAULT_MODEL_PATH = MODELS_DIR / "best.pt"


# Correspondance classe -> valeur en euros
def _value_from_class_name(name: str) -> float:
    """Retourne la valeur d'une classe, en gerant les labels FR et EN.

    Reconnait par exemple '50_centimes', '2_euros' et 'EUR-50-cent'.
    Tout label non reconnu vaut 0.0 (classe parasite).
    """
    n = name.lower().replace("_", "-").strip()

    # On ramene "centimes" sur "cent" pour gerer les deux langues
    n = n.replace("centimes", "cent").replace("centime", "cent")
    n = n.replace("euros", "euro")

    if "1-euro" in n or n in ("1euro", "1e"):
        return 1.00
    if "2-euro" in n or n in ("2euro", "2e"):
        return 2.00

    # Centimes : on teste les nombres a deux chiffres en premier
    cent_map = {
        "50": 0.50, "20": 0.20, "10": 0.10,
        "5": 0.05, "2": 0.02, "1": 0.01,
    }
    for digit, value in cent_map.items():
        if f"{digit}-cent" in n or f"{digit}cent" in n:
            return value
        if n == f"{digit}c":
            return value

    return 0.0


def value_from_label(label: str) -> float:
    """Valeur en euros d'un label, quelle que soit la langue (0.0 si inconnu)."""
    return _value_from_class_name(label)


def _load_classes_from_yaml(yaml_path: Path) -> list:
    try:
        if not yaml_path.exists():
            return []
        with open(yaml_path, "r") as f:
            cfg = yaml.safe_load(f)
        names = cfg.get("names", {}) if cfg else {}
        if isinstance(names, dict):
            return [names[i] for i in sorted(names.keys())]
        return list(names)
    except (FileNotFoundError, OSError, KeyError, TypeError):
        return []


_DEFAULT_CLASS_NAMES = [
    "1c", "2c", "5c", "10c", "20c", "50c", "1e", "2e",
]

_loaded = _load_classes_from_yaml(DATA_YAML)
CLASS_NAMES = _loaded if _loaded else _DEFAULT_CLASS_NAMES

COIN_VALUES = {name: _value_from_class_name(name) for name in CLASS_NAMES}


def _color_for_value(value):
    if value == 0.0:
        return (128, 128, 128)
    if value < 0.10:
        return (40, 100, 180)
    if value < 1.0:
        return (0, 215, 255)
    return (200, 200, 200)


CLASS_COLORS = {name: _color_for_value(COIN_VALUES[name]) for name in CLASS_NAMES}
IGNORED_CLASSES = {name for name, v in COIN_VALUES.items() if v == 0.0}


